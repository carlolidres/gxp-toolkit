# GxP Toolkit — environment variable template (committed reference)
#
# Copy to .env.local for local development:
#   cp .env.example .env.local        (Unix/macOS)
#   copy .env.example .env.local      (Windows PowerShell / CMD)
#
# Only VITE_* variables are inlined into the client bundle at build time.
# Never put real secrets in this file — use placeholders only.
# Real Supabase URL and anon key belong in .env.local (gitignored).

# Supabase (optional until @supabase/supabase-js is integrated)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Application environment label (development | staging | production)
VITE_APP_ENV=development

# GitHub Pages subpath when repo is not at domain root (e.g. /gxp-toolkit/)
# Leave empty or use ./ for root deploy; CI sets this via workflow when needed
VITE_BASE_PATH=/gxp-toolkit/
# VITE_GITHUB_PAGES=true

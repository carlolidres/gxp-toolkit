{
  "name": "gxp-toolkit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "type-check": "tsc -b",
    "typecheck": "tsc -b",
    "e2e": "playwright test",
    "e2e:edoc-staging": "playwright test --config playwright.edoc-staging.config.ts",
    "edoc:provision-test-users": "node scripts/provision-edoc-staging-test-users.mjs",
    "edoc:seed-staging-test": "supabase db query --linked -f supabase/scripts/seed_edoc_staging_test_accounts.sql",
    "edoc:revert-real-user-pilot": "supabase db query --linked -f supabase/scripts/revert_edoc_real_user_pilot.sql",
    "repair:vrms-audit": "node scripts/repair-vrms-audit-bundle.mjs",
    "verify:vrms-csv": "node scripts/verify-vrms-csv-bundle.mjs",
    "db:map": "node scripts/generate-sqlite-map.mjs",
    "db:init": "node scripts/db-init.mjs",
    "db:update": "node scripts/db-update.mjs",
    "verify:schema": "node scripts/verify-schema-sync.mjs",
    "verify:edoc-sqlite": "node scripts/verify-edoc-sqlite.mjs",
    "supabase:seed:vrms": "node scripts/generate-vrms-supabase-seed.mjs",
    "workflow:dev": "python workflow-app/server.py",
    "workflow:validate": "python workflow-app/scripts/validate_schema.py",
    "workflow:smoke": "python workflow-app/scripts/smoke_test.py"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@supabase/supabase-js": "^2.49.4",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "recharts": "^2.15.3",
    "typescript-eslint": "^8.62.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  }
}
